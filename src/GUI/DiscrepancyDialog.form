<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="GUI.DiscrepancyDialog">
  <grid id="27dc6" binding="contentPane" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="6b6ea" binding="westPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="West"/>
        <properties/>
        <border type="none"/>
        <children/>
      </grid>
      <grid id="6a694" binding="centerPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="bbbed" class="javax.swing.JButton" binding="btnNewLogEntry">
            <constraints border-constraint="South"/>
            <properties>
              <text value="New Log Entry"/>
            </properties>
          </component>
          <scrollpane id="cc98" binding="scrollLogEntries">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <grid id="a2f0" binding="pnlLogEntries" custom-create="true" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints/>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </scrollpane>
        </children>
      </grid>
    </children>
  </grid>
</form>
